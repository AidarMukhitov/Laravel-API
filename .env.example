APP_NAME="Landing Page API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ============================================================
# Mail Configuration
# ============================================================
# Options: smtp, log, array
# Use 'log' for testing (emails written to storage/logs/laravel.log)
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Email address of the site owner who receives contact notifications
MAIL_OWNER=admin@example.com

# ============================================================
# OpenAI / AI Configuration
# ============================================================
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# Rate Limiting (POST /api/contact)
# ============================================================
RATE_LIMIT_ATTEMPTS=3
RATE_LIMIT_DECAY=60

# ============================================================
# Cache (file driver — no Redis needed)
# ============================================================
CACHE_STORE=file
CACHE_PREFIX=landing_api_
